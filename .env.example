# Railway
PORT=5179
NODE_ENV=production

# TiDB Cloud / MySQL
# Example: mysql://USER:PASSWORD@HOST:4000/DATABASE?ssl={"rejectUnauthorized":true}
DATABASE_URL=

# Cloudflare R2
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional. Use a public R2 custom domain if prepared.
# Example: https://files.samwon.site
R2_PUBLIC_BASE_URL=

# Optional
MAX_BODY_BYTES=125829120
MAX_PHOTO_BYTES=12582912
DB_CONNECTION_LIMIT=4
MIN_PASSWORD_LENGTH=8
ADMIN_EMAILS=
